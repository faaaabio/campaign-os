# Copy this file to .env and fill in real values. .env is git-ignored.

# Where new campaigns get scaffolded. Set this per client so /sprint-start writes
# into the client's private repo instead of cluttering the framework checkout.
# If unset, campaigns are created under ./campaigns/ inside this repo.
# Example: CAMPAIGN_OS_CAMPAIGNS_DIR=/Users/you/Documents/buybike/campaigns
CAMPAIGN_OS_CAMPAIGNS_DIR=

# Higgsfield MCP authenticates via OAuth on first connect, but if you use a
# personal API key, set it here.
HIGGSFIELD_API_KEY=

# Meta Ads MCP — long-lived access token from the Meta Business app.
META_ADS_ACCESS_TOKEN=

# Google Drive MCP — OAuth token for the workspace you'll sync to.
GOOGLE_DRIVE_OAUTH_TOKEN=
